# .env.example
# Copy this file to .env and fill in your actual keys

# Gemini API Key (Required for AI Chatbot)
GEMINI_API_KEY=your_gemini_api_key_here

# Razorpay Payment Gateway (Indian Payment Gateway)
RAZORPAY_KEY_ID=rzp_test_your_key_id_here
RAZORPAY_KEY_SECRET=your_razorpay_key_secret_here

# SMS 2FA API Keys (e.g., Twilio / Msg91)
SMS_API_KEY=your_sms_api_key_here
SMS_SENDER_ID=CIVIC_APP

# Indian Data Store (e.g., AWS ap-south-1 Mumbai or Supabase Mumbai)
DATABASE_URL=postgres://user:password@mumbai-db.example.in:5432/publicproject
